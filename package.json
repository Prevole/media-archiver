{
  "name": "media-archiver",
  "version": "0.0.2",
  "description": "Archiver for media files imported from mobile devices",
  "repository": "github:Prevole/media-archiver",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "media-archiver": "dist/bin/media-archiver.js"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist && rm -f tsconfig.tsbuildinfo",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --watch --config vitest.e2e.config.ts",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint src/**/*.ts e2e/**/*.ts",
    "lint:fix": "eslint src/**/*.ts e2e/**/*.ts --fix"
  },
  "keywords": [
    "media",
    "archiver",
    "photos",
    "videos"
  ],
  "author": "Prevole",
  "license": "MIT",
  "dependencies": {
    "cli-progress": "^3.12.0",
    "command-line-args": "^6.0.1",
    "js-yaml": "^4.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@types/cli-progress": "^3.11.6",
    "@types/command-line-args": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-formatter-rdjson": "^1.0.6",
    "eslint-plugin-import-x": "^4.16.2",
    "semantic-release": "^25.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5"
  }
}
